# ==============================================================================
# MedPharma Plus - Environment Variables Template
# ==============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# IMPORTANT:
# - Never commit .env.local to version control
# - Generate secure secrets for production
# - Use environment-specific values for different deployments
# ==============================================================================

# ==============================================================================
# DATABASE - PostgreSQL (Required)
# ==============================================================================
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
#
# Local development:
#   DATABASE_URL="postgresql://postgres:password@localhost:5432/medpharma"
#
# Railway:
#   DATABASE_URL="postgresql://postgres:xxx@xxx.proxy.rlwy.net:5432/railway"
#
DATABASE_URL="postgresql://postgres:password@localhost:5432/medpharma"

# ==============================================================================
# NEXTAUTH.JS - Admin Authentication (Required)
# ==============================================================================
# Secret key for encrypting sessions and tokens
# Generate with: openssl rand -base64 32
# IMPORTANT: Use a unique, secure value in production!
NEXTAUTH_SECRET="your-secret-key-generate-with-openssl-rand-base64-32"

# Base URL of your application (no trailing slash)
# Development: http://localhost:3000
# Production: https://your-domain.com
NEXTAUTH_URL="http://localhost:3000"

# ==============================================================================
# SITE CONFIGURATION (Required)
# ==============================================================================
# Public URL of the site (used in emails, SEO, Open Graph)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Site name displayed in UI and meta tags
NEXT_PUBLIC_SITE_NAME="MedPharma Plus"

# Default locale: "ka" (Georgian) or "en" (English)
NEXT_PUBLIC_DEFAULT_LOCALE="ka"

# ==============================================================================
# CLOUDFLARE R2 STORAGE - Product Images (Required for image uploads)
# ==============================================================================
# Cloudflare R2 is recommended for this project:
# ✅ Free egress (unlimited downloads)
# ✅ Built-in global CDN
# ✅ S3-compatible API
# ✅ Cheaper than AWS S3
# ✅ Fast performance in Georgia/Europe
#
# Setup Instructions:
# 1. Create R2 bucket: https://dash.cloudflare.com → R2 → Create Bucket
# 2. Get API credentials: R2 → Manage R2 API Tokens → Create API Token
# 3. Enable public access: Bucket Settings → Public Access → Allow
# 4. Get public URL: Bucket Settings → R2.dev subdomain (or use custom domain)
#
# For detailed setup guide, see: R2_SETUP.md (Georgian instructions)
# ==============================================================================

# R2 Endpoint URL
# Format: https://ACCOUNT_ID.r2.cloudflarestorage.com
# Get from: Cloudflare Dashboard → R2 → Bucket → Settings
# Example: https://a1b2c3d4e5f6g7h8.r2.cloudflarestorage.com
S3_ENDPOINT="https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com"

# R2 Region
# For R2, use "auto" or "weur" (Western Europe recommended for Georgia)
# R2 automatically replicates to nearest location
S3_REGION="auto"

# R2 Bucket Name
# Must match the bucket name you created in Cloudflare R2 dashboard
# Recommendation: Use different buckets for dev/production
# Dev: medpharma-uploads-dev
# Prod: medpharma-uploads
S3_BUCKET="medpharma-uploads"

# R2 API Credentials
# Get from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
# Permissions required: Object Read & Write
# IMPORTANT: Keep these secret! Never commit to git
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# R2 Public URL
# Option 1: R2.dev subdomain (free, automatic)
#   Format: https://pub-XXXXXXXXXX.r2.dev
#   Get from: Bucket Settings → R2.dev subdomain → Enable
#   Example: S3_PUBLIC_URL="https://pub-abc123xyz.r2.dev"
#
# Option 2: Custom domain (recommended for production)
#   Format: https://uploads.yourdomain.com
#   Setup: Bucket Settings → Custom Domains → Connect Domain
#   Example: S3_PUBLIC_URL="https://uploads.medpharma.ge"
#
# Leave empty to use default R2 endpoint (not recommended - slower)
S3_PUBLIC_URL=""

# ==============================================================================
# Alternative S3-Compatible Storage Providers (if not using R2)
# ==============================================================================
# If you prefer AWS S3, DigitalOcean Spaces, or MinIO instead:
#
# AWS S3:
#   S3_ENDPOINT="https://s3.us-east-1.amazonaws.com"
#   S3_REGION="us-east-1"
#
# DigitalOcean Spaces:
#   S3_ENDPOINT="https://fra1.digitaloceanspaces.com"
#   S3_REGION="fra1"
#
# MinIO (local development):
#   S3_ENDPOINT="http://localhost:9000"
#   S3_REGION="us-east-1"
#
# ==============================================================================

# ==============================================================================
# PAYMENTS - TBC E-COMMERCE (Required for TBC card payments)
# ==============================================================================
# TBC Bank e-Commerce API credentials
# Register at: https://developers.tbcbank.ge/
#
# Client ID and Secret from TBC developer portal
TBC_CLIENT_ID=""
TBC_CLIENT_SECRET=""

# API endpoint
# Sandbox: https://api.tbcbank.ge/v1 (same as production for TBC)
# Production: https://api.tbcbank.ge/v1
TBC_API_URL="https://api.tbcbank.ge/v1"

# Callback URLs (must be HTTPS in production)
TBC_REDIRECT_URL="http://localhost:3000/api/payment/tbc/callback"
TBC_SUCCESS_URL="http://localhost:3000/checkout/success"
TBC_FAIL_URL="http://localhost:3000/checkout/failure"

# ==============================================================================
# PAYMENTS - BOG IPAY (Required for BOG card payments)
# ==============================================================================
# Bank of Georgia iPay API credentials
# Register at: https://ipay.ge/
#
# Client ID and Secret Key from iPay merchant portal
BOG_CLIENT_ID=""
BOG_SECRET_KEY=""

# API endpoint
# Sandbox: https://ipay.ge/opay/api/v1
# Production: https://ipay.ge/opay/api/v1
BOG_API_URL="https://ipay.ge/opay/api/v1"

# Callback URLs (must be HTTPS in production)
BOG_REDIRECT_URL="http://localhost:3000/api/payment/bog/callback"
BOG_SUCCESS_URL="http://localhost:3000/checkout/success"
BOG_FAIL_URL="http://localhost:3000/checkout/failure"

# ==============================================================================
# EMAIL - Transactional Emails (Required for order confirmations)
# ==============================================================================
# Choose ONE provider: SMTP or Resend
#
# Email provider to use: "smtp" or "resend"
EMAIL_PROVIDER="smtp"

# --- Option 1: SMTP (Gmail, SendGrid, Mailgun, etc.) ---
# SMTP server hostname
SMTP_HOST="smtp.gmail.com"
# SMTP port (587 for TLS, 465 for SSL, 25 for unencrypted)
SMTP_PORT="587"
# Use TLS/SSL
SMTP_SECURE="false"
# SMTP authentication
SMTP_USER=""
SMTP_PASSWORD=""
# From address (format: "Name <email@example.com>")
SMTP_FROM="MedPharma Plus <noreply@medpharma.ge>"

# --- Option 2: Resend (https://resend.com) ---
# Resend API key (starts with re_)
RESEND_API_KEY=""
# From address
RESEND_FROM="MedPharma Plus <noreply@medpharma.ge>"

# ==============================================================================
# APEX ERP INTEGRATION (Optional - Future Feature)
# ==============================================================================
# APEX ERP API endpoint for product/inventory sync
APEX_API_URL=""

# API authentication key
APEX_API_KEY=""

# Webhook secret for verifying incoming webhooks from APEX
APEX_WEBHOOK_SECRET=""

# Sync interval in minutes (for scheduled background jobs)
APEX_SYNC_INTERVAL="30"

# ==============================================================================
# SECURITY & RATE LIMITING (Recommended for production)
# ==============================================================================
# Maximum requests per minute per IP address
RATE_LIMIT_MAX="100"

# Enable/disable rate limiting (set to "false" for development)
RATE_LIMIT_ENABLED="true"

# ==============================================================================
# ANALYTICS (Optional)
# ==============================================================================
# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# Facebook Pixel ID
NEXT_PUBLIC_FB_PIXEL_ID=""

# ==============================================================================
# DEVELOPMENT & DEBUGGING (Development only)
# ==============================================================================
# Enable verbose debug logging
DEBUG="false"

# Log Prisma database queries (useful for debugging)
PRISMA_LOG_QUERIES="false"

# ==============================================================================
# QUICK START CHECKLIST
# ==============================================================================
# Minimum required for development:
# [x] DATABASE_URL - PostgreSQL connection
# [x] NEXTAUTH_SECRET - Generate a secure secret
# [x] NEXTAUTH_URL - Set to http://localhost:3000
# [x] NEXT_PUBLIC_SITE_URL - Set to http://localhost:3000
#
# For full functionality:
# [ ] S3_* - Required for image uploads
# [ ] TBC_* or BOG_* - Required for online payments
# [ ] SMTP_* or RESEND_* - Required for email notifications
# ==============================================================================
